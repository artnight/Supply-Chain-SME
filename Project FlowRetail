      "cell_type": "code",
      "source": [
        "# WHY: customer_taxonomies feeds into RFM segmentation with prior labels.\n",
        "# Is_loyalty_member is used as a feature weight in the uplift model.\n",
        "\n",
        "customer_master = pd.DataFrame({\n",
        "    'customer_id': customer_ids,\n",
