# 5. AUTOMATED MASTER CONTROLLER (ระบบสลับแท็บอัตโนมัติ)
# ==========================================
def master_controller(category, store):
    clear_output(wait=True)
    display(ui_controls)
    
    # ทำการกรองข้อมูลตาม Widget ที่ยูสเซอร์เลือกเปลี่ยนหน้าจอ
    filtered_df = main_df.copy()
    if category != 'ทั้งหมด (All)':
        filtered_df = filtered_df[filtered_df['final_category'] == category]
    if store != 'ทั้งหมด (All)':
        filtered_df = filtered_df[filtered_df['final_store'] == store]
        
    # สร้างระบบแท็บใน Jupyter Notebook
    tab = widgets.Tab()
    tab_outputs = [widgets.Output() for _ in range(4)]
    tab.children = tab_outputs
    
    tab.set_title(0, '📊 Overview & Trend')
    tab.set_title(1, '🎯 Revenue Pareto (80/20)')
    tab.set_title(2, '👥 Customer Cluster')
    tab.set_title(3, '🧠 Feature Importance')
    display(tab)
    
    # เรนเดอร์กราฟแต่ละตัวลงไปในแท็บของตัวเอง
    with tab_outputs[0]: render_tab1_overview(filtered_df, category, store)
    with tab_outputs[1]: render_tab2_pareto(filtered_df, category)
    with tab_outputs[2]: render_tab3_kmeans(filtered_df)
    with tab_outputs[3]: render_tab4_importance()

# สั่งให้แอปพลิเคชันเริ่มทำงานและคอยดักจับ Event การกดเลือกใน Dropdown
out = widgets.interactive_output(master_controller, {'category': dropdown_category, 'store': dropdown_store})
display(out)
