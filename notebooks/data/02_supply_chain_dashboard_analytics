# ==========================================
# 2. DATA PIPELINE & FALLBACK HANDLING (ดึงข้อมูลจากโฟลเดอร์ data/)
# ==========================================
# เชื่อมต่อไปยังฐานข้อมูลตามโครงสร้าง notebooks/data/supply_chain_sme_v2.db
db_path = "data/supply_chain_sme_v2.db"
conn = sqlite3.connect(db_path)

try:
    sales_df = pd.read_sql_query("SELECT * FROM sales_transaction", conn)
    product_df = pd.read_sql_query("SELECT * FROM product_master", conn)
    
    # พยายามดึงข้อมูลลูกค้า หากไม่มีตาราง ให้สร้าง DataFrame จำลองเพื่อไม่ให้ระบบล่ม
    try:
        customer_df = pd.read_sql_query("SELECT * FROM customer_master", conn)
    except:
        customer_df = pd.DataFrame({'customer_id': sales_df['customer_id'].unique() if 'customer_id' in sales_df.columns else range(1, 500)})
        
    print("✅ [Data Pipeline] ดึงข้อมูลจากฐานข้อมูล SQLite สำเร็จ!")
except sqlite3.OperationalError as e:
    conn.close()
    raise RuntimeError(f"❌ ไม่พบตารางในฐานข้อมูล! กรุณาตรวจสอบว่าได้รันไฟล์ 01_generate_mock_data_to_db_... เพื่อสร้างข้อมูลแล้วหรือยัง: {e}")
finally:
    conn.close()

# ผสานตารางธุรกรรมเข้ากับตารางสินค้าหลัก
main_df = sales_df.merge(product_df, on='product_id', how='left')

# --- ตรวจสอบและดักจับคอลัมน์แบบยืดหยุ่น (Defensive Mapping) ---
price_col = next((c for c in ['price', 'base_price', 'Price', 'unit_price'] if c in main_df.columns), None)
main_df['final_price'] = main_df[price_col] if price_col else 100.0

qty_col = next((c for c in ['qty', 'quantity', 'Qty'] if c in main_df.columns), None)
main_df['final_qty'] = main_df[qty_col] if qty_col else 1

cat_col = next((c for c in ['product_taxonomies', 'category', 'product_category'] if c in main_df.columns), None)
main_df['final_category'] = main_df[cat_col] if cat_col else 'Uncategorized'

store_col = next((c for c in ['store_id', 'store', 'store_taxonomies'] if c in main_df.columns), None)
main_df['final_store'] = main_df[store_col] if store_col else 'Main Store'

# คำนวณตัวเลขทางการเงินสำหรับการวิเคราะห์
main_df['revenue'] = main_df['final_qty'] * main_df['final_price']
main_df['cost'] = main_df['final_price'] * 0.65  # สมมุติฐานต้นทุนที่ 65%
main_df['total_cost'] = main_df['final_qty'] * main_df['cost']
main_df['profit'] = main_df['revenue'] - main_df['total_cost']

# จัดการข้อมูลวันที่
if 'datetime' in main_df.columns:
    main_df['datetime'] = pd.to_datetime(main_df['datetime'])
    main_df['date'] = main_df['datetime'].dt.date
else:
    main_df['date'] = pd.to_datetime('today').date()

# ==========================================
# 3. INTERACTIVE WIDGETS CONFIGURATION
# ==========================================
categories = ['ทั้งหมด (All)'] + sorted(main_df['final_category'].dropna().unique().tolist())
stores = ['ทั้งหมด (All)'] + sorted(main_df['final_store'].dropna().unique().tolist())

dropdown_category = widgets.Dropdown(options=categories, description='📦 หมวดหมู่สินค้า:', style={'description_width': 'initial'})
dropdown_store = widgets.Dropdown(options=stores, description='🏢 สาขาร้านค้า:', style={'description_width': 'initial'})
ui_controls = widgets.HBox([dropdown_category, dropdown_store])

