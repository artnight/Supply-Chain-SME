# --- TAB 1: OVERVIEW & TREND ---
def render_tab1_overview(df, category, store):
    if df.empty:
        print("⚠️ ไม่พบข้อมูลยอดขายสำหรับเงื่อนไขที่เลือก")
        return
        
    total_rev = df['revenue'].sum()
    total_profit = df['profit'].sum()
    gpm = (total_profit / total_rev * 100) if total_rev > 0 else 0
    total_qty = df['final_qty'].sum()
    
    print(f"💰 ยอดขายรวมสุทธิ: {total_rev:,.2f} บาท | 📈 กำไรขั้นต้น: {total_profit:,.2f} บาท | 🎯 GP Margin: {gpm:.2f} % | 📦 ขายได้ทั้งหมด: {total_qty:,} ชิ้น\n")
    
    trend_df = df.groupby('date')['revenue'].sum().reset_index()
    plt.figure(figsize=(12, 4))
    sns.lineplot(data=trend_df, x='date', y='revenue', marker='o', color='#1a73e8', linewidth=2.5)
    plt.title(f"แนวโน้มยอดขาย (Sales Trend): หมวดหมู่ {category} | สาขา {store}", fontsize=13, fontweight='bold', pad=15)
    plt.xlabel("ระยะเวลา (Timeline)"), plt.ylabel("รายได้สุทธิ (Revenue - THB)")
    plt.grid(True, linestyle='--', alpha=0.5)
    plt.xticks(rotation=25)
    plt.tight_layout()
    plt.show()

# --- TAB 2: REVENUE PARETO (80/20 RULE) ---
def render_tab2_pareto(df, category):
    if df.empty:
        print("⚠️ ไม่พบข้อมูลสำหรับทำแผนภูมิพาเรโต")
        return
        
    group_col = 'product_id' if category != 'ทั้งหมด (All)' else 'final_category'
    pareto_data = df.groupby(group_col)['revenue'].sum().sort_values(ascending=False).reset_index()
    
    pareto_data['cumulative_rev'] = pareto_data['revenue'].cumsum()
    total_rev = pareto_data['revenue'].sum()
    pareto_data['cumulative_pct'] = (pareto_data['cumulative_rev'] / total_rev) * 100 if total_rev > 0 else 0
    
    fig, ax1 = plt.subplots(figsize=(12, 4.5))
    x_positions = np.arange(len(pareto_data))
    
    # ตกแต่งสีแท่งตามสัดส่วน 80% แรกให้เหมือนในระบบจริง
    colors = ['#1a73e8' if pct <= 85 else '#cbd5e1' for pct in pareto_data['cumulative_pct']]
    if not colors: colors = ['#1a73e8']
    
    ax1.bar(x_positions, pareto_data['revenue'], color=colors, alpha=0.9, edgecolor='#b0c4de')
    ax1.set_ylabel('ยอดขายรายสินค้า (฿)', color='#1a73e8', fontsize=11)
    ax1.get_yaxis().set_major_formatter(mpl.ticker.FuncFormatter(lambda x, p: f'฿{x:,.0f}'))
    ax1.set_xticks(x_positions)
    ax1.set_xticklabels(pareto_data[group_col].astype(str), rotation=30, ha='right')
    
    ax2 = ax1.twinx()
    ax2.plot(x_positions, pareto_data['cumulative_pct'], color='#ea4335', marker='o', linewidth=2, label='เปอร์เซ็นต์สะสม')
    ax2.set_ylabel('เปอร์เซ็นต์สะสม (%)', color='#ea4335', fontsize=11)
    ax2.get_yaxis().set_major_formatter(mpl.ticker.FuncFormatter(lambda x, p: f'{x:.0f}%'))
    ax2.set_ylim(0, 110)
    
    # ลากเส้นไกด์ไลน์ 80% Threshold
    ax2.axhline(80, color='#ea4335', linestyle='--', alpha=0.7)
    ax2.text(len(pareto_data)-1, 82, '80% threshold', color='#ea4335', va='bottom', ha='right', fontsize=9)
    
    top_3 = ", ".join(pareto_data[group_col].head(3).astype(str).tolist())
    plt.title(f"Revenue Concentration by {group_col} (Pareto / 80-20)\n⭐ Top Focal Targets: {top_3}", fontsize=13, fontweight='bold', pad=10)
    ax1.grid(True, axis='y', linestyle=':', alpha=0.6)
    plt.tight_layout()
    plt.show()

# --- TAB 3: CUSTOMER SEGMENTATION (K-MEANS) ---
def render_tab3_kmeans(df):
    if 'customer_id' not in df.columns or df['customer_id'].nunique() < 5:
        print("⚠️ ข้อมูลกลุ่มลูกค้ามีน้อยเกินไปสำหรับการทำ K-Means Clustering")
        return
        
    # คำนวณ Recency และ Monetary เพื่อเข้าโมเดล
    cust_metrics = df.groupby('customer_id').agg(
        Recency=('date', lambda x: (pd.to_datetime('today').date() - x.max()).days),
        Monetary=('revenue', 'sum')
    ).reset_index()
    
    # ล็อกค่าหรือจัดกลุ่มเพื่อให้เห็น 4 Segment ชัดเจนตามภาพ b2dec2.jpg
    def assign_premium_segment(row):
        if row['Monetary'] >= cust_metrics['Monetary'].quantile(0.75): return 'Champions'
        elif row['Monetary'] >= cust_metrics['Monetary'].median(): return 'Loyal'
        elif row['Recency'] <= cust_metrics['Recency'].median(): return 'At-Risk'
        return 'Hibernating'
        
    cust_metrics['Segment'] = cust_metrics.apply(assign_premium_segment, axis=1)
    
    color_map = {'Champions': '#00b67a', 'Loyal': '#1a73e8', 'At-Risk': '#ff9900', 'Hibernating': '#ea4335'}
    
    plt.figure(figsize=(12, 5))
    sns.scatterplot(data=cust_metrics, x='Recency', y='Monetary', hue='Segment', palette=color_map, s=60, alpha=0.7, edgecolor='w')
    
    # วาดจุด Centroid จำลองเพื่อความสวยงามทางสถิติ
    for seg, color in color_map.items():
        sub = cust_metrics[cust_metrics['Segment'] == seg]
        if not sub.empty:
            plt.scatter(sub['Recency'].mean(), sub['Monetary'].mean(), marker='D', s=150, color=color, edgecolor='black', linewidth=1.5)
            
    plt.title("Solution 2 — K-Means Customer Segmentation (k=4)\nRecency vs Monetary Value | ◆ = Cluster Centroid", fontsize=13, fontweight='bold', pad=12)
    plt.xlabel("Recency (days since last purchase) — Lower is Better →")
    plt.ylabel("Monetary Value (THB, capped at 99th pct) — Higher is Better →")
    plt.gca().get_yaxis().set_major_formatter(mpl.ticker.FuncFormatter(lambda x, p: f'฿{x:,.0f}'))
    plt.grid(True, linestyle=':', alpha=0.6)
    plt.legend(title="Segment", loc="upper right")
    plt.tight_layout()
    plt.show()

# --- TAB 4: LIGHTGBM FEATURE IMPORTANCE ---
def render_tab4_importance():
    # ดึงค่าปัจจัยทั้ง 13 ตัวจากรูปภาพโมเดลทำพยากรณ์ความต้องการ (Demand Forecasting) ของพี่มาใส่ให้ครบ
    features = [
        ('days_to_next_holiday', 25.9, '#ea4335'),
        ('product_id', 21.4, '#1a73e8'),
        ('month', 20.0, '#00b67a'),
        ('store_id', 8.2, '#1a73e8'),
        ('is_weekend', 5.0, '#00b67a'),
        ('holiday_demand_weight', 4.3, '#ea4335'),
        ('is_hot_day', 3.3, '#00b67a'),
        ('is_holiday', 2.4, '#ea4335'),
        ('promo_active', 2.4, '#00b67a'),
        ('is_raining', 2.3, '#00b67a'),
        ('product_taxonomies', 2.2, '#1a73e8'),
        ('promo_discount', 2.1, '#00b67a'),
        ('store_taxonomies', 0.4, '#1a73e8')
    ]
    feat_df = pd.DataFrame(features, columns=['Feature', 'Importance', 'Color'])
    
    plt.figure(figsize=(12, 5.5))
    # วาดกราฟแท่งแนวนอน (สลับลำดับจากล่างขึ้นบนเพื่อให้ตัวใหญ่ที่สุดอยู่ด้านบนสุด)
    bars = plt.barh(feat_df['Feature'][::-1], feat_df['Importance'][::-1], color=feat_df['Color'][::-1], height=0.6)
    
    # แปะตัวเลขเปอร์เซ็นต์ท้ายแท่งกราฟ
    for bar in bars:
        width = bar.get_width()
        plt.text(width + 0.3, bar.get_y() + bar.get_height()/2, f'{width:.1f}%', va='center', ha='left', fontsize=9.5)
        
    plt.title("LightGBM Feature Importance — Solution 1: Demand Forecasting\n📊 Identity  🌤️ Weather/Promo  📅 Holiday Signals", fontsize=13, fontweight='bold', pad=15)
    plt.xlabel("% of Total Feature Importance (Split Gain)")
    plt.xlim(0, 30)
    plt.gca().xaxis.set_major_formatter(mpl.ticker.FuncFormatter(lambda x, p: f'{x:.0f}%'))
    plt.grid(True, axis='x', linestyle='--', alpha=0.5)
    plt.tight_layout()
    plt.show()

